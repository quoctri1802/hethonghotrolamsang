{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/index.html", "dest": "/public/index.html" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/admin.html", "dest": "/public/admin.html" },
    { "src": "/styles.css", "dest": "/public/styles.css" },
    { "src": "/app.js", "dest": "/public/app.js" },
    { "src": "/admin.js", "dest": "/public/admin.js" },
    { "src": "/logo.png", "dest": "/public/logo.png" }
  ]
}
